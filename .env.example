# ==========================================
# 核心配置
# ==========================================
# 发部的时候记得替换成你的生产环境地址
NEXT_PUBLIC_SITE_URL=http://localhost:8000

# ==========================================
# AI 服务提供商配置
# ==========================================
# 可以是 `openai` 或 `gemini`。如果不设置则默认回退到 gemini。
AI_PROVIDER=openai

# 如果采用 openai，配置你的 OpenAI 的 API 分发地址（或者代理地址）
OPENAI_API_KEY=sk-your-openai-api-key

# 如果采用 gemini，配置你的 Google API Key
GEMINI_API_KEY=AIzaSy...

# ==========================================
# 鉴权配置 (NextAuth)
# ==========================================
# 你可以通过 `npx auth secret` 来生成一个新的 AUTH_SECRET
AUTH_SECRET=your_generated_auth_secret_here
AUTH_TRUST_HOST=true

# ==========================================
# 数据库配置 (Supabase)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
